# Database (MySQL connection string)
DATABASE_URL=mysql://user:password@host:3306/bookhou_prod

# App URL (your production domain, used for links in emails/SMS)
APP_URL=https://yourdomain.com

# CORS (must match your frontend domain)
CORS_ORIGIN=https://yourdomain.com

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Node environment (set to "production" for HTTPS cookies)
NODE_ENV=production

# Server port
PORT=3002

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...

# Twilio (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# SendGrid (from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG....
SENDER_EMAIL=your-verified@email.com

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/google-calendar/callback
